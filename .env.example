# Finrenone — environment template
#
# Copy this file to `.env` and fill in real values before running.
# Never commit your .env (it is gitignored).

# Path to RapidMeta NMA template HTML
RAPIDMETA_NMA_TEMPLATE=

# Absolute path to your local RapidMeta installation
RAPIDMETA_ROOT=

# Path to Rscript.exe used by RapidMeta
RAPIDMETA_RSCRIPT=
